# ── Stream Video ─────────────────────────────────────────
STREAM_API_KEY=your_stream_api_key
STREAM_API_SECRET=your_stream_api_secret
NEXT_PUBLIC_STREAM_API_KEY=your_stream_api_key   # same key, exposed to browser

# ── Google / Gemini ─────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key
GEMINI_REALTIME_MODEL=gemini-2.5-flash-native-audio-preview  # optional override

# ── Backend Server ──────────────────────────────────────
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Frontend → Backend (Vercel) ─────────────────────────
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080       # e.g. https://your-backend.fly.dev
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws/metrics   # e.g. wss://your-backend.fly.dev/ws/metrics
